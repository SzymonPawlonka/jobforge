{
  "info": {
    "name": "JobForge",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Pełny scenariusz JobForge. Upload wymaga ręcznego wskazania pliku."
  },
  "variable": [],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"{{email}}\", \"password\": \"{{password}}\"}"
        },
        "url": "{{base_url}}/auth/register"
      }
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('login 200', () => pm.response.to.have.status(200));",
              "pm.environment.set('token', pm.response.json().access_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "username",
              "value": "{{email}}"
            },
            {
              "key": "password",
              "value": "{{password}}"
            }
          ]
        },
        "url": "{{base_url}}/auth/login"
      }
    },
    {
      "name": "Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/users/me"
      }
    },
    {
      "name": "Create job",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('created', () => pm.response.to.have.status(201));",
              "pm.environment.set('job_id', pm.response.json().id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"name\": \"Analiza raportu\"}"
        },
        "url": "{{base_url}}/jobs"
      }
    },
    {
      "name": "List jobs",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/jobs"
      }
    },
    {
      "name": "Get job",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/jobs/{{job_id}}"
      }
    },
    {
      "name": "Update job",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"name\": \"Zmieniona analiza raportu\"}"
        },
        "url": "{{base_url}}/jobs/{{job_id}}"
      }
    },
    {
      "name": "Upload file (choose file)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "upload",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": "{{base_url}}/jobs/{{job_id}}/file"
      }
    },
    {
      "name": "Download file",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/jobs/{{job_id}}/file"
      }
    },
    {
      "name": "Run job",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/jobs/{{job_id}}/run"
      }
    },
    {
      "name": "My stats",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/stats/me"
      }
    },
    {
      "name": "Delete file",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/jobs/{{job_id}}/file"
      }
    },
    {
      "name": "Delete job",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/jobs/{{job_id}}"
      }
    }
  ]
}
