# PostgreSQL
POSTGRES_DB=jobforge
POSTGRES_USER=jobforge
POSTGRES_PASSWORD=jobforge
POSTGRES_PORT=5432

# Python API
DATABASE_URL=postgresql+psycopg://jobforge:jobforge@db:5432/jobforge
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARACTERS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
GRPC_TARGET=analyzer:50051
GRPC_TLS=false
GRPC_TIMEOUT_SECONDS=10
CORS_ORIGINS=*
LOG_LEVEL=INFO

# Initial administrator
ADMIN_EMAIL=admin@jobforge.com
ADMIN_PASSWORD=ChangeMe123!

# Go analyzer
ANALYZER_MAX_FILE_BYTES=1048576

